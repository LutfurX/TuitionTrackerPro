{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user's tuition settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Student": {
      "title": "Student",
      "description": "A student managed by the educator.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date", "description": "ISO 8601 date string (YYYY-MM-DD)" },
        "tuitionTime": { "type": "string", "description": "Time of tuition (HH:MM)" },
        "daysPerMonth": { "type": "number" },
        "monthlySalary": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "startDate", "createdAt"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "A single teaching date record for a specific student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "ISO 8601 date string (YYYY-MM-DD)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "studentId", "date", "createdAt"]
    },
    "SalaryRecord": {
      "title": "Salary Record",
      "description": "A salary payment record for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "studentId", "studentName", "month", "amount", "createdAt"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An exam record for a student or teacher.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "customSubject": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "totalMarks": { "type": "number" },
        "obtainedMarks": { "type": "number" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["subject", "date", "totalMarks", "obtainedMarks", "createdAt", "uid"]
    },
    "Journal": {
      "title": "Journal",
      "description": "A class journal entry describing what was taught.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "subject": { "type": "string" },
        "customSubject": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "subject", "content", "createdAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A reminder for a class or payment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["class", "payment"] },
        "studentId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/students/{studentId}": {
      "schema": "Student",
      "description": "Students managed by the user."
    },
    "/users/{userId}/attendance/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Attendance records for students."
    },
    "/users/{userId}/salary/{recordId}": {
      "schema": "SalaryRecord",
      "description": "Salary records for students."
    },
    "/users/{userId}/exams/{examId}": {
      "schema": "Exam",
      "description": "Exam records for students or teachers."
    },
    "/users/{userId}/journal/{journalId}": {
      "schema": "Journal",
      "description": "Class journal entries."
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Reminders for classes and payments."
    }
  }
}
